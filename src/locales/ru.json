  "tests": {
    "smoke": [
      {
        "id": "smoke-basic-entry",
        "name": "Базовый вход",
        "type": "smoke",
        "description": "Критичная проверка доступности бота и первого ответа.",
        "estimatedMinutes": 1,
        "steps": [
          {
            "id": "open-bot",
            "title": "Открыть бота",
            "expectedResult": "Бот открывается и готов к работе.",
            "checks": ["Бот открыт", "Интерфейс отвечает"]
          },
          {
            "id": "trigger-start",
            "title": "Вызвать /start",
            "expectedResult": "Первое сообщение появляется быстро и без ошибок.",
            "checks": ["Сообщение получено", "Нет задержки", "Нет ошибок"]
          },
          {
            "id": "verify-first-message",
            "title": "Проверить первое сообщение",
            "expectedResult": "Текст сообщения отображается полностью.",
            "checks": ["Текст виден", "Нет пустых плейсхолдеров"]
          }
        ]
      },
      {
        "id": "smoke-button-interaction",
        "name": "Проверка кнопки",
        "type": "smoke",
        "description": "Проверка основной кнопки и ответного сообщения.",
        "estimatedMinutes": 1,
        "steps": [
          {
            "id": "click-main-button",
            "title": "Нажать основную кнопку",
            "expectedResult": "Кнопка нажимается без дублей действий.",
            "checks": ["Кнопка кликабельна", "Нет блокировки"]
          },
          {
            "id": "verify-response-message",
            "title": "Проверить ответ",
            "expectedResult": "Сообщение корректно обновляется и не дублируется.",
            "checks": ["Сообщение изменилось", "Нет дублей", "Нет зависания UI"]
          }
        ]
      },
      {
        "id": "smoke-automation-trigger",
        "name": "Триггер автоматизации",
        "type": "smoke",
        "description": "Проверка запуска автоматизации по событию.",
        "estimatedMinutes": 2,
        "steps": [
          {
            "id": "trigger-event",
            "title": "Вызвать событие (тег или действие)",
            "expectedResult": "Событие принято системой.",
            "checks": ["Событие отправлено", "Нет мгновенной ошибки"]
          },
          {
            "id": "wait-automation",
            "title": "Дождаться автоматизации",
            "expectedResult": "Автоматизация выполнена и сообщение доставлено.",
            "checks": ["Автоматизация сработала", "Сообщение доставлено"]
          }
        ]
      },
      {
        "id": "smoke-message-rendering",
        "name": "Рендер сообщения",
        "type": "smoke",
        "description": "Проверка отображения текста, кнопок и ссылок.",
        "estimatedMinutes": 1,
        "steps": [
          {
            "id": "receive-message",
            "title": "Получить сообщение",
            "expectedResult": "Сообщение отображается без визуальных проблем.",
            "checks": ["Текст виден", "Кнопки видны", "Нет сломанной верстки", "Нет битых ссылок"]
