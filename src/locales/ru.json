          {
            "id": "open-bot",
            "title": "Открыть бота",
            "expectedResult": "Бот открыт успешно.",
            "checks": ["Точка входа доступна", "Нет ошибок"]
          },
          {
            "id": "start-scenario",
            "title": "Запустить сценарий",
            "expectedResult": "Сценарий стартовал, начальное состояние показано.",
            "checks": ["Есть первое сообщение", "Состояние корректно"]
          },
          {
            "id": "click-button",
            "title": "Нажать кнопку",
            "expectedResult": "Клик запускает ожидаемый переход.",
            "checks": ["Кнопка кликабельна", "Нет дубля обработки"]
