{
  "scenarios": [
    {
      "id": "scenario-test-tg-bot",
      "name": "Тест TG-бота",
      "steps": [
        {
          "id": "tg-open-bot",
          "title": "Открыть Telegram-бота и проверить доступность",
          "checks": [
            "Бот открывается без ошибок",
            "Профиль и аватар бота отображаются",
            "Команда /start доступна"
          ]
        },
        {
          "id": "tg-start-flow",
          "title": "Запустить стартовый сценарий",
          "checks": [
            "Стартовое сообщение получено",
            "Текст сообщения корректный",
            "Клавиатура/кнопки отображаются"
          ]
        },
        {
          "id": "tg-menu-navigation",
          "title": "Пройти ключевые ветки меню",
          "checks": [
            "Переходы по кнопкам работают",
            "В каждой ветке приходит ожидаемый ответ",
            "Нет дублирующихся сообщений"
          ]
        },
        {
          "id": "tg-variables-and-tags",
          "title": "Проверить переменные и теги пользователя",
          "checks": [
            "Имя/данные пользователя подставляются корректно",
            "Теги назначаются после действий",
            "Теги видны в карточке подписчика"
          ]
        },
        {
          "id": "tg-broadcast-delivery",
          "title": "Проверить доставку рассылки в TG",
          "checks": [
            "Рассылка доходит до пользователя",
            "Кнопки в рассылке кликабельны",
            "Ссылки открываются без ошибок"
          ]
        },
        {
          "id": "tg-error-resilience",
          "title": "Проверить устойчивость к невалидному вводу",
          "checks": [
            "Бот отвечает на произвольный текст",
            "Нет падений сценария",
            "Пользователь возвращается в рабочую ветку"
          ]
        }
      ]
    },
    {
